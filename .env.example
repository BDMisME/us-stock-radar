# =========================================================
#  us-stock-radar — environment configuration
#  Copy to ".env" and fill in. Never commit the real .env.
# =========================================================

# --- Alpaca Market Data (IEX websocket, 30 real-time symbols) ---
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# --- Backup quote / history / news providers ---
FINNHUB_API_KEY=
FMP_API_KEY=

# --- LLM (AI analyst — any OpenAI-compatible provider) ---
# Examples:
#   OpenAI:          LLM_API_KEY=sk-...   LLM_BASE_URL=   LLM_MODEL=gpt-4o
#   Groq:            LLM_API_KEY=gsk_...  LLM_BASE_URL=https://api.groq.com/openai/v1  LLM_MODEL=llama-3.3-70b-versatile
#   Volcengine ARK:  LLM_API_KEY=...      LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3  LLM_MODEL=<endpoint-id>
#   Gemini (compat): LLM_API_KEY=...      LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/  LLM_MODEL=gemini-2.0-flash
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# --- Telegram notifications ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Email (SMTP) notifications ---
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
EMAIL_TO=

# --- Database ---
# On Zeabur: set DB_PATH=/data/us_stock_radar.sqlite  (mount persistent volume at /data)
# Local dev: keep as-is
DB_PATH=./db/us_stock_radar.sqlite

# --- Optional tuning (sane defaults applied if blank) ---
# Polling interval (seconds) for the 70 general watchlist names
WATCHLIST_POLL_SECONDS=120
# AI worker scan interval (seconds)
AI_WORKER_INTERVAL_SECONDS=30
# Alert worker scan interval (seconds)
ALERT_WORKER_INTERVAL_SECONDS=15
# AI analysis cooldown per category (hours)
AI_COOLDOWN_CORE_HOURS=2
AI_COOLDOWN_FOCUS_HOURS=4

# --- Optional personal branding (sidebar credit) ---
# Leave blank for the generic open-source credit.
# Set to personalise your own instance, e.g. APP_CREDIT_NAME=Your Name
APP_CREDIT_NAME=
